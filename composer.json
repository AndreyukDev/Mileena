{
  "name": "andreyukdev/mileena",
  "description": "Mileena, lightweight business PHP Framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Artem Andreyuk"
    }
  ],
  "config": {
    "platform": {
      "php": "8.4"
    }
  },
  "require": {
    "php": ">=8.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Mileena\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mileena\\Public\\": "public/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "vendor/bin/phpstan analyse --configuration=phpstan.neon",
    "fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
    "test": "phpunit"
  }
}